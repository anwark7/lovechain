# ─────────────────────────────────────────────────────────────
# LoveChain — example environment file.
# Copy to `.env` (root, for contracts) and fill in real values.
# NEVER commit your real .env — it is gitignored.
# All values below are testnet-only. Do NOT use a mainnet key here.
# ─────────────────────────────────────────────────────────────

# ── Contract deployment (packages/contracts) ────────────────

# RPC endpoints for the testnets you want to deploy to.
# Get free keys from Alchemy / Infura, or use a public RPC.
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# Deployer private key (testnet wallet ONLY — never a real one).
# Fund it from a Sepolia faucet before deploying.
DEPLOYER_PRIVATE_KEY="0xyour_testnet_private_key"

# Optional: for contract verification on Etherscan / Basescan.
ETHERSCAN_API_KEY=""
BASESCAN_API_KEY=""

# ── Demo timing windows (seconds) — set at deploy time ──────
# PRD uses short windows so flows can be demoed live.
COOLING_PERIOD_SECONDS="180"       # peaceful-exit cooling (3 min)
CHALLENGE_PERIOD_SECONDS="180"     # breach challenge + voting window (3 min)
WEDDING_WINDOW_SECONDS="180"       # wedding approval window (3 min)

# Default share of the ACCUSED partner's deposit awarded to a
# claimant on a VALID breach, in basis points. 10000 = 100%.
BREACH_AWARD_BPS="10000"


# ─────────────────────────────────────────────────────────────
# Frontend (packages/web) — these belong in packages/web/.env.local
# (prefixed with NEXT_PUBLIC_ so the browser can read them).
# ─────────────────────────────────────────────────────────────

# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Injected wallets like MetaMask work without it for a local demo.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Deployed LoveChain address per chain (filled after deploy).
NEXT_PUBLIC_LOVECHAIN_ADDRESS_SEPOLIA=""
NEXT_PUBLIC_LOVECHAIN_ADDRESS_BASE_SEPOLIA=""

# Default chain the UI connects to: "sepolia" or "baseSepolia".
NEXT_PUBLIC_DEFAULT_CHAIN="sepolia"
